{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure SnakeGame",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "command": "cmake",
      "args": [
        "-S",
        "SnakeGame",
        "-B",
        "SnakeGame/build",
        "-G",
        "MinGW Makefiles"
      ],
      "problemMatcher": []
    },
    {
      "label": "Build SnakeGame",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "command": "cmake",
      "args": [
        "--build",
        "SnakeGame/build"
      ],
      "dependsOn": "Configure SnakeGame",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
